# Clerk configuration and rerouting URLs for authentication flows.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Supabase configuration for database connection and authentication.
NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
DATABASE_URL=postgresql://postgres.replace-me.supabase.co:5432/postgres

# Optional local-only auth bypass for latency/debug work without Clerk production keys.
PAPERDECK_DEV_AUTH=false
PAPERDECK_DEV_OWNER_ID=local-dev-user
DATABASE_MAX_CONNECTIONS=1
# Debug logging level (debug, info, warn, error)
LOG_LEVEL=info

# arXiv ingestion worker
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CR,cs.CC,cs.DS,cs.LG,cs.LO,cs.PL,cs.SE,cs.SY
ARXIV_MAX_RESULTS=25
ARXIV_USER_AGENT=PaperDeck/0.1.0 (https://paperdeck.example.com)

# Semantic Scholar enrichment worker (api key is optional for lower-rate free tier)
SEMANTIC_SCHOLAR_API_KEY=
S2_BATCH_SIZE=100
S2_LIMIT=500
S2_REQUEST_DELAY_MS=1100
CLASSIC_S2_RETRIES=3
CLASSIC_S2_RETRY_DELAY_MS=10000
CLASSIC_DISCOVERY_PER_QUERY=8
CLASSIC_DISCOVERY_MAX_NEW_PER_QUERY=2
CLASSIC_DISCOVERY_MAX_YEAR=2020
CLASSIC_DISCOVERY_REQUEST_DELAY_MS=1100
CLASSIC_DISCOVERY_RETRIES=3
CLASSIC_DISCOVERY_RETRY_DELAY_MS=10000
CLASSIC_DISCOVERY_EMBEDDING_LIMIT=96
CLASSIC_DISCOVERY_TOPIC_EMBEDDING_LIMIT=64

# OpenAlex enrichment worker (email is optional, enables polite pool for higher rate limits)
OPENALEX_BATCH_SIZE=25
OPENALEX_LIMIT=500
OPENALEX_REQUEST_DELAY_MS=200
OPENALEX_EMAIL=

# Unpaywall enrichment worker (email recommended for higher rate limits)
UNPAYWALL_LIMIT=500
UNPAYWALL_REQUEST_DELAY_MS=500
UNPAYWALL_EMAIL=

# LLM summary worker
# GitHub Models (recommended in GitHub Actions):
#   LLM_PROVIDER=github
#   LLM_MODEL=openai/gpt-4o-mini
#   In Actions this uses the built-in GITHUB_TOKEN with permissions: models: read.
LLM_PROVIDER=github
LLM_MODEL=openai/gpt-4o-mini
GITHUB_MODELS_TOKEN=
# Cloudflare Workers AI fallback:
#   LLM_MODEL=@cf/zai-org/glm-4.7-flash
#   Token needs Workers AI Read + Workers AI Write permissions.
CLOUDFLARE_ACCOUNT_ID=replace_me
CLOUDFLARE_API_TOKEN=replace_me
# Gemini fallback:
#   LLM_PROVIDER=gemini
#   LLM_MODEL=gemini-flash-latest
#   LLM_API_KEY=replace_me
LLM_API_KEY=
# OpenAI direct:
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=replace_me
OPENAI_API_KEY=
LLM_BATCH_SIZE=1
LLM_LIMIT=3
LLM_REQUEST_DELAY_MS=10000
LLM_RETRIES=5
LLM_SOURCE_TEXT_CHARS=8000
LLM_MAX_INPUT_CHARS=500000
LLM_MAX_OUTPUT_TOKENS=1600

# Jina AI Reader for full-paper text extraction (optional, better rate limits with key)
JINA_API_KEY=

# Embedding worker
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_TOPIC_LIMIT=256
EMBEDDING_TOPIC_TABLE_LIMIT=0
EMBEDDING_LIMIT=256
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TABLE_LIMIT=0
