NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
# Optional in production. Comma-separated allowed origins for Clerk session tokens.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,https://paperdeck.example.com
# Optional local-only auth bypass for latency/debug work without Clerk production keys.
PAPERDECK_DEV_AUTH=false
PAPERDECK_DEV_OWNER_ID=local-dev-user

NEXT_PUBLIC_SUPABASE_URL=https://replace-me.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# arXiv ingestion worker
ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CR,cs.CC,cs.DS,cs.LG,cs.LO,cs.PL,cs.SE,cs.SY
ARXIV_MAX_RESULTS=25
ARXIV_USER_AGENT=PaperDeck/0.1.0 (https://paperdeck.example.com)

# Semantic Scholar enrichment worker (api key is optional for lower-rate free tier)
SEMANTIC_SCHOLAR_API_KEY=
S2_BATCH_SIZE=100
S2_LIMIT=500
S2_REQUEST_DELAY_MS=1100

# OpenAlex enrichment worker (email is optional, enables polite pool for higher rate limits)
OPENALEX_BATCH_SIZE=25
OPENALEX_LIMIT=500
OPENALEX_REQUEST_DELAY_MS=200
OPENALEX_EMAIL=

# Unpaywall enrichment worker (email recommended for higher rate limits)
UNPAYWALL_LIMIT=500
UNPAYWALL_REQUEST_DELAY_MS=500
UNPAYWALL_EMAIL=

# LLM summary worker (OpenAI-compatible API, required)
# Google Gemini free tier (recommended):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   LLM_MODEL=gemini-2.0-flash
#   Get your key at https://aistudio.google.com/apikey
LLM_API_KEY=replace_me
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash
LLM_BATCH_SIZE=5
LLM_LIMIT=50
LLM_REQUEST_DELAY_MS=20000

# Jina AI Reader for full-paper text extraction (optional, better rate limits with key)
JINA_API_KEY=

# Embedding worker
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_TOPIC_LIMIT=256
EMBEDDING_TOPIC_TABLE_LIMIT=0
EMBEDDING_LIMIT=256
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TABLE_LIMIT=0
